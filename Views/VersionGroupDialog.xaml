<Window x:Class="Sibang_generator.Views.VersionGroupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="모델 추가" Height="440" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PanelBg}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="Head" Grid.Row="0" Text="모델 추가"
                   FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentDark}"
                   Margin="0,0,0,12" />

        <TextBlock Grid.Row="1" Text="버전" Style="{StaticResource FieldLabel}" />
        <ComboBox x:Name="CbVersion" Grid.Row="2" IsEditable="True" Margin="0,4,0,4"
                  SelectionChanged="Ver_Changed" KeyUp="Ver_Typed" />

        <StackPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock Text="모델명 (콤마 · 줄바꿈 · 세미콜론 구분)" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="TbModels" AcceptsReturn="True" Height="150" Margin="0,4"
                     VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                     TextChanged="Models_Changed" />
        </StackPanel>

        <TextBlock x:Name="VerHint" Grid.Row="4" Style="{StaticResource FieldLabel}"
                   TextWrapping="Wrap" Margin="0,4" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="Warn" Foreground="#C8500A" VerticalAlignment="Center"
                       Margin="0,0,14,0" />
            <Button x:Name="OkBtn" Content="확인" Style="{StaticResource PrimaryButton}"
                    Padding="24,8" Click="Ok_Click" />
            <Button Content="취소" Margin="8,0,0,0" Padding="20,8" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="Sibang_generator.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="clr-namespace:Sibang_generator.Models"
        Title="설정" Height="720" Width="860"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PanelBg}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="Transparent">

            <!-- Region → 라벨 매핑 -->
            <TabItem Header="Region 라벨">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,8"
                               Text="Region 코드를 한글/영문 라벨로 매핑합니다. Language 가 비면 KOR→KOR, 나머지→ENG 로 자동 유도합니다." />
                    <DataGrid Grid.Row="1" x:Name="RegionGrid" AutoGenerateColumns="False"
                              CanUserAddRows="True" HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal" Background="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Region" Binding="{Binding Region}" Width="120" />
                            <DataGridTextColumn Header="한글 라벨" Binding="{Binding Ko}" Width="180" />
                            <DataGridTextColumn Header="영문 라벨" Binding="{Binding En}" Width="240" />
                            <DataGridTextColumn Header="Language" Binding="{Binding Language}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="선택 행 삭제" Click="DeleteRegion_Click" />
                        <Button Content="기본값 복원" Click="ResetRegion_Click" Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- 상수 섹션 (0,2,3,5,7,8,9) -->
            <TabItem Header="상수 섹션 (한/영)">
                <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"
                                   Text="기존 시방 txt 를 첨부하지 않았을 때 사용하는 0,2,3,5,7,8,9 기본 본문입니다. 헤더 줄 포함." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="한글" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="0. 시방목적" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="Ko0" Text="{Binding Ko.S0}" AcceptsReturn="True" MinHeight="30" Margin="0,2,0,6" />
                                <TextBlock Text="2. 모델타입" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="Ko2" Text="{Binding Ko.S2}" AcceptsReturn="True" MinHeight="30" Margin="0,2,0,6" />
                                <TextBlock Text="3. 적용시점" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="Ko3" Text="{Binding Ko.S3}" AcceptsReturn="True" MinHeight="30" Margin="0,2,0,6" />
                                <TextBlock Text="5. 변경내용" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="Ko5" Text="{Binding Ko.S5}" AcceptsReturn="True" MinHeight="30" Margin="0,2,0,6" />
                                <TextBlock Text="7. 출하환경" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="Ko7" Text="{Binding Ko.S7}" AcceptsReturn="True" MinHeight="50" Margin="0,2,0,6" />
                                <TextBlock Text="8. 재고" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="Ko8" Text="{Binding Ko.S8}" AcceptsReturn="True" MinHeight="45" Margin="0,2,0,6" />
                                <TextBlock Text="9. 기타" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="Ko9" Text="{Binding Ko.S9}" AcceptsReturn="True" MinHeight="45" Margin="0,2,0,6" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="English" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="0. Purpose" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding En.S0}" AcceptsReturn="True" MinHeight="30" Margin="0,2,0,6" />
                                <TextBlock Text="2. Model Type" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding En.S2}" AcceptsReturn="True" MinHeight="30" Margin="0,2,0,6" />
                                <TextBlock Text="3. Application Time" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding En.S3}" AcceptsReturn="True" MinHeight="30" Margin="0,2,0,6" />
                                <TextBlock Text="5. Change Details" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding En.S5}" AcceptsReturn="True" MinHeight="30" Margin="0,2,0,6" />
                                <TextBlock Text="7. Shipping environment" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding En.S7}" AcceptsReturn="True" MinHeight="50" Margin="0,2,0,6" />
                                <TextBlock Text="8. Stock" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding En.S8}" AcceptsReturn="True" MinHeight="45" Margin="0,2,0,6" />
                                <TextBlock Text="9. Other" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding En.S9}" AcceptsReturn="True" MinHeight="45" Margin="0,2,0,6" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 6번 고정 골격 템플릿 -->
            <TabItem Header="6. 제조환경 골격 (한↔영)">
                <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"
                                   Text="6번 고정 문구입니다. 모델 리스트는 자동으로 채워지므로 여기엔 없습니다. {SW} 는 S/W Version 줄이 들어갈 자리입니다." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="한글 골격" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="헤더 / Copy 안내 / CMD / Boot" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding Ko6.Header}" Margin="0,2" />
                                <TextBox Text="{Binding Ko6.CopyIntro}" Margin="0,2" />
                                <TextBox Text="{Binding Ko6.CmdLine}" Margin="0,2" />
                                <TextBox Text="{Binding Ko6.BootLine}" Margin="0,2" />
                                <TextBlock Text="검사 안내 / 검사 항목" Style="{StaticResource FieldLabel}" Margin="0,6,0,0" />
                                <TextBox Text="{Binding Ko6.TestsIntro}" Margin="0,2" />
                                <TextBox Text="{Binding Ko6.TestsBody}" AcceptsReturn="True" MinHeight="120" Margin="0,2" />
                                <TextBlock Text="LCD 안내 / Wi-Fi 안내 / 중간 / Region 안내" Style="{StaticResource FieldLabel}" Margin="0,6,0,0" />
                                <TextBox Text="{Binding Ko6.LcdIntro}" AcceptsReturn="True" MinHeight="45" Margin="0,2" />
                                <TextBox Text="{Binding Ko6.LcdWifiIntro}" Margin="0,2" />
                                <TextBox Text="{Binding Ko6.LcdMiddle}" AcceptsReturn="True" MinHeight="110" Margin="0,2" />
                                <TextBox Text="{Binding Ko6.LcdRegionIntro}" Margin="0,2" />
                                <TextBox Text="{Binding Ko6.SwVersionLabel}" Margin="0,2" />
                                <TextBlock Text="재작업 소제목 (6-1 / 6-2)" Style="{StaticResource FieldLabel}" Margin="0,6,0,0" />
                                <TextBox Text="{Binding Ko6.ReworkHeader}" Margin="0,2" />
                                <TextBox Text="{Binding Ko6.JigHeader}" Margin="0,2" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="English 골격" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Header / Copy / CMD / Boot" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding En6.Header}" Margin="0,2" />
                                <TextBox Text="{Binding En6.CopyIntro}" Margin="0,2" />
                                <TextBox Text="{Binding En6.CmdLine}" Margin="0,2" />
                                <TextBox Text="{Binding En6.BootLine}" Margin="0,2" />
                                <TextBlock Text="Tests intro / body" Style="{StaticResource FieldLabel}" Margin="0,6,0,0" />
                                <TextBox Text="{Binding En6.TestsIntro}" Margin="0,2" />
                                <TextBox Text="{Binding En6.TestsBody}" AcceptsReturn="True" MinHeight="120" Margin="0,2" />
                                <TextBlock Text="LCD intro / Wi-Fi / middle / Region" Style="{StaticResource FieldLabel}" Margin="0,6,0,0" />
                                <TextBox Text="{Binding En6.LcdIntro}" AcceptsReturn="True" MinHeight="45" Margin="0,2" />
                                <TextBox Text="{Binding En6.LcdWifiIntro}" Margin="0,2" />
                                <TextBox Text="{Binding En6.LcdMiddle}" AcceptsReturn="True" MinHeight="110" Margin="0,2" />
                                <TextBox Text="{Binding En6.LcdRegionIntro}" Margin="0,2" />
                                <TextBox Text="{Binding En6.SwVersionLabel}" Margin="0,2" />
                                <TextBlock Text="Rework headers (6-1 / 6-2)" Style="{StaticResource FieldLabel}" Margin="0,6,0,0" />
                                <TextBox Text="{Binding En6.ReworkHeader}" Margin="0,2" />
                                <TextBox Text="{Binding En6.JigHeader}" Margin="0,2" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 6-1 재작업 테스트 한↔영 번역 -->
            <TabItem Header="재작업 테스트 번역 (한↔영)">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,8"
                               Text="6-1) 구미 재작업 공정의 테스트 항목은 엑셀에 한글로 들어있습니다. 영문 시방을 만들 때 이 표로 줄 단위 번역합니다. 한글 문구가 정확히 일치해야 매칭됩니다 (번호는 빼고 입력)." />
                    <DataGrid Grid.Row="1" x:Name="ReworkGrid" AutoGenerateColumns="False"
                              CanUserAddRows="True" HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal" Background="White"
                              ColumnWidth="*">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="한글 (엑셀 원문)" Binding="{Binding Ko}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="English" Binding="{Binding En}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="선택 행 삭제" Click="DeleteRework_Click" />
                        <Button Content="기본값 복원" Click="ResetRework_Click" Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="저장" Style="{StaticResource PrimaryButton}" Padding="28,8" Click="Save_Click" />
            <Button Content="취소" Margin="8,0,0,0" Padding="20,8" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="Sibang_generator.Views.BomOverrideDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BOM 직접 지정" Height="400" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PanelBg}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="Head" FontSize="15" FontWeight="Bold"
                   Foreground="{StaticResource AccentDark}" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" x:Name="Sub" Style="{StaticResource FieldLabel}" Margin="0,0,0,10" />

        <TextBlock Grid.Row="2" Text="BOM 직접 입력" Style="{StaticResource FieldLabel}" />
        <TextBox Grid.Row="2" x:Name="TbBom" Margin="90,0,0,0" TextChanged="Bom_Changed" />

        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock Text="폴더에서 발견된 BOM 후보 (클릭)" Style="{StaticResource FieldLabel}" />
            <ListBox x:Name="LbBoms" Height="150" Margin="0,4"
                     SelectionChanged="Bom_Selected" />
        </StackPanel>

        <TextBlock Grid.Row="4" x:Name="FolderHint" Style="{StaticResource FieldLabel}"
                   Margin="0,6" TextWrapping="Wrap" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="지정" Style="{StaticResource PrimaryButton}" Padding="24,8" Click="Ok_Click" />
            <Button Content="취소" Margin="8,0,0,0" Padding="20,8" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
